# =============================================================================
# DATABASE
# =============================================================================
# SQLite (local development) - Prisma uses this
DATABASE_URL="file:./db/custom.db"

# =============================================================================
# NEXT AUTH
# =============================================================================
# Generate a secret: run `openssl rand -base64 32` or use https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LoyaChat"

# =============================================================================
# FILE UPLOAD (optional - configure if using cloud storage)
# =============================================================================
# UPLOAD_DIR="./upload"

# =============================================================================
# OAUTH PROVIDERS (optional - add if using social login)
# =============================================================================
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
